{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kiseen.ai/plugin.schema.json",
  "title": "KISEEN Plugin Manifest",
  "description": "KISEEN Browser Agent Runtime 插件清单格式",
  "type": "object",
  "required": ["name", "version", "actions"],
  "properties": {
    "name": {
      "type": "string",
      "description": "插件唯一标识，如 'form-autofill'",
      "pattern": "^[a-z0-9_-]+$"
    },
    "version": {
      "type": "string",
      "description": "语义化版本",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "description": "插件功能简述"
    },
    "author": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "enum": ["browser_action", "dom_tool", "observation", "validation", "recovery"] },
      "description": "插件提供的能力类型"
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "需要的特殊权限"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "parameters"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "description": {
            "type": "string",
            "maxLength": 200
          },
          "parameters": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["type", "required", "description"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["string", "number", "boolean", "object", "array"]
                },
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          },
          "safety": {
            "type": "object",
            "properties": {
              "cooldownMs": { "type": "number", "default": 500 },
              "dangerous": { "type": "boolean", "default": false },
              "maxPerSession": { "type": "number", "default": 100 }
            }
          }
        }
      }
    },
    "contentScript": {
      "type": "string",
      "description": "Content Script 处理文件路径（相对于插件目录）"
    },
    "sidepanel": {
      "type": "string",
      "description": "SidePanel 处理文件路径（相对于插件目录）"
    },
    "selectorHints": {
      "type": "object",
      "description": "站点 Selector 提示",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "domain": { "type": "string" },
          "selectors": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
